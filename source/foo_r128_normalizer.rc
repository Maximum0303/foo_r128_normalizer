#pragma code_page(65001)

#include <windows.h>
#include <commctrl.h>
#include "resource.h"

IDD_R128_CONFIG DIALOGEX 0, 0, 520, 327
STYLE DS_SHELLFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_CONTEXTHELP | WS_EX_CONTROLPARENT
CAPTION "R128 音量ノーマライザー"
FONT 9, "Yu Gothic UI"
BEGIN
    CONTROL         "", IDC_CONFIG_TABS, WC_TABCONTROL,
                    TCS_TABS | TCS_SINGLELINE | WS_TABSTOP,
                    8, 7, 504, 190

    LTEXT           "左列：R128補正・測定", IDC_BASIC_HEADER,
                    20, 31, 220, 12
    LTEXT           "右列：True Peak保護・ゲイン固定", IDC_BASIC_RIGHT_HEADER,
                    270, 31, 232, 12

    LTEXT           "目標ラウドネス：", IDC_LABEL_TARGET_LUFS,
                    20, 49, 126, 12, SS_NOTIFY
    EDITTEXT        IDC_TARGET_LUFS, 148, 46, 38, 14,
                    ES_AUTOHSCROLL | ES_RIGHT
    LTEXT           "LUFS", IDC_UNIT_TARGET_LUFS,
                    190, 49, 48, 12

    LTEXT           "R128補正ゲイン最大増幅量：", IDC_LABEL_MAX_BOOST,
                    20, 69, 126, 12, SS_NOTIFY
    EDITTEXT        IDC_MAX_BOOST, 148, 66, 38, 14,
                    ES_AUTOHSCROLL | ES_RIGHT
    LTEXT           "dB", IDC_UNIT_MAX_BOOST,
                    190, 69, 48, 12

    LTEXT           "R128補正ゲイン最大減衰量：", IDC_LABEL_MAX_ATTENUATION,
                    20, 89, 126, 12, SS_NOTIFY
    EDITTEXT        IDC_MAX_ATTENUATION, 148, 86, 38, 14,
                    ES_AUTOHSCROLL | ES_RIGHT
    LTEXT           "dB", IDC_UNIT_MAX_ATTENUATION,
                    190, 89, 48, 12

    LTEXT           "曲頭安定化解析時間：", IDC_LABEL_STARTUP,
                    20, 109, 126, 12, SS_NOTIFY
    EDITTEXT        IDC_STARTUP_ANALYSIS_SECONDS, 148, 106, 38, 14,
                    ES_AUTOHSCROLL | ES_RIGHT
    LTEXT           "秒", IDC_UNIT_STARTUP,
                    190, 109, 48, 12

    LTEXT           "静音保護しきい値：", IDC_LABEL_SILENCE_THRESHOLD,
                    20, 129, 126, 12, SS_NOTIFY
    EDITTEXT        IDC_SILENCE_GUARD_LUFS, 148, 126, 38, 14,
                    ES_AUTOHSCROLL | ES_RIGHT
    LTEXT           "LUFS", IDC_UNIT_SILENCE_THRESHOLD,
                    190, 129, 48, 12

    CONTROL         "トラック変更時に測定値をリセット",
                    IDC_RESET_EACH_TRACK, "Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP, 20, 151, 230, 13
    CONTROL         "静音区間では増幅を保留",
                    IDC_ENABLE_SILENCE_GUARD, "Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP, 20, 170, 230, 13

    LTEXT           "True Peak上限：", IDC_LABEL_TRUE_PEAK,
                    270, 49, 128, 12, SS_NOTIFY
    EDITTEXT        IDC_TRUE_PEAK, 400, 46, 38, 14,
                    ES_AUTOHSCROLL | ES_RIGHT
    LTEXT           "dBTP", IDC_UNIT_TRUE_PEAK,
                    442, 49, 48, 12

    LTEXT           "True Peakリミッター先読み時間：", IDC_LABEL_LOOKAHEAD,
                    270, 69, 128, 12, SS_NOTIFY
    EDITTEXT        IDC_LOOKAHEAD_MS, 400, 66, 38, 14,
                    ES_AUTOHSCROLL | ES_RIGHT
    LTEXT           "ms", IDC_UNIT_LOOKAHEAD,
                    442, 69, 48, 12

    LTEXT           "True Peakリミッター解放時間：", IDC_LABEL_LIMITER_RELEASE,
                    270, 89, 128, 12, SS_NOTIFY
    EDITTEXT        IDC_LIMITER_RELEASE_MS, 400, 86, 38, 14,
                    ES_AUTOHSCROLL | ES_RIGHT
    LTEXT           "ms", IDC_UNIT_LIMITER_RELEASE,
                    442, 89, 48, 12

    LTEXT           "補正ゲイン固定判定時間：", IDC_LABEL_GAIN_LOCK_SECONDS,
                    270, 109, 128, 12, SS_NOTIFY
    EDITTEXT        IDC_GAIN_LOCK_SECONDS, 400, 106, 38, 14,
                    ES_AUTOHSCROLL | ES_RIGHT
    LTEXT           "秒", IDC_UNIT_GAIN_LOCK_SECONDS,
                    442, 109, 48, 12

    LTEXT           "補正ゲイン固定許容幅：", IDC_LABEL_GAIN_LOCK_TOLERANCE,
                    270, 129, 128, 12, SS_NOTIFY
    EDITTEXT        IDC_GAIN_LOCK_TOLERANCE_LU, 400, 126, 38, 14,
                    ES_AUTOHSCROLL | ES_RIGHT
    LTEXT           "LU", IDC_UNIT_GAIN_LOCK_TOLERANCE,
                    442, 129, 48, 12

    CONTROL         "True Peak保護（先読みリミッター）を有効",
                    IDC_ENABLE_PEAK_GUARD, "Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP, 270, 151, 232, 13
    CONTROL         "安定後に曲中の補正ゲインを固定",
                    IDC_ENABLE_GAIN_LOCK, "Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP, 270, 170, 232, 13

    LTEXT           "追加マスタリング処理（任意）", IDC_ADV_HEADER,
                    20, 31, 240, 12

    GROUPBOX        "モダン処理", IDC_ADV_GROUP_MODERN,
                    14, 47, 156, 92
    CONTROL         "有効にする",
                    IDC_ENABLE_MODERN_BOOST, "Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP, 24, 63, 132, 13
    LTEXT           "コンプレッサー、ソフトクリッパー、True Peakリミッターを組み合わせます。",
                    IDC_ADV_INFO_1, 24, 82, 136, 43

    GROUPBOX        "1バンド・アダプティブ", IDC_ADV_GROUP_ADAPTIVE,
                    176, 47, 156, 92
    CONTROL         "有効にする",
                    IDC_ENABLE_ADAPTIVE_MASTER, "Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP, 186, 63, 132, 13
    LTEXT           "曲の音量とLRAに応じて、モダン処理の強度を自動調整します。",
                    IDC_ADV_INFO_2, 186, 82, 136, 43

    GROUPBOX        "3バンド・アダプティブ", IDC_ADV_GROUP_THREE_BAND,
                    338, 47, 168, 92
    CONTROL         "有効にする",
                    IDC_ENABLE_THREE_BAND_MASTER, "Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP, 348, 63, 144, 13
    LTEXT           "低域・中域・高域に分け、それぞれの処理量を個別に制御します。",
                    IDC_ADV_INFO_3, 348, 82, 148, 43

    GROUPBOX        "共通の処理強度", IDC_ADV_GROUP_STRENGTH,
                    14, 147, 492, 41
    LTEXT           "モダン処理強度／アダプティブ上限：", IDC_LABEL_MODERN_STRENGTH,
                    24, 162, 238, 12, SS_NOTIFY
    EDITTEXT        IDC_MODERN_STRENGTH, 270, 159, 42, 14,
                    ES_AUTOHSCROLL | ES_RIGHT
    LTEXT           "%（0～100）", IDC_UNIT_MODERN_STRENGTH,
                    320, 162, 88, 12

    LTEXT           "現在値・処理状態（上から下へ）", IDC_DIAG_LEFT_HEADER,
                    18, 31, 234, 10
    LTEXT           "ピーク・環境・最大値（上から下へ）", IDC_DIAG_RIGHT_HEADER,
                    270, 31, 232, 10

    LTEXT           "R128ノーマライズ状態：", IDC_LABEL_DIAG_NORMALIZATION,
                    18, 48, 128, 10, SS_NOTIFY
    LTEXT           "待機中", IDC_DIAG_NORMALIZATION_STATE,
                    148, 48, 104, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "補正ゲイン固定状態：", IDC_LABEL_DIAG_GAIN_LOCK,
                    18, 58, 128, 10, SS_NOTIFY
    LTEXT           "待機中", IDC_DIAG_GAIN_LOCK,
                    148, 58, 104, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "Momentaryラウドネス：", IDC_LABEL_DIAG_MOMENTARY,
                    18, 68, 128, 10, SS_NOTIFY
    LTEXT           "待機中", IDC_DIAG_MOMENTARY,
                    148, 68, 104, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "Short-termラウドネス：", IDC_LABEL_DIAG_SHORT_TERM,
                    18, 78, 128, 10, SS_NOTIFY
    LTEXT           "待機中", IDC_DIAG_SHORT_TERM,
                    148, 78, 104, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "入力Integratedラウドネス：", IDC_LABEL_DIAG_INPUT_INT,
                    18, 88, 128, 10, SS_NOTIFY
    LTEXT           "待機中", IDC_DIAG_INTEGRATED,
                    148, 88, 104, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "出力Integratedラウドネス：", IDC_LABEL_DIAG_OUTPUT_INT,
                    18, 98, 128, 10, SS_NOTIFY
    LTEXT           "待機中", IDC_DIAG_OUTPUT_INTEGRATED,
                    148, 98, 104, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "目標LUFSとの差：", IDC_LABEL_DIAG_TARGET_DIFF,
                    18, 108, 128, 10, SS_NOTIFY
    LTEXT           "待機中", IDC_DIAG_TARGET_DIFFERENCE,
                    148, 108, 104, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "ラウドネスレンジ（LRA）：", IDC_LABEL_DIAG_LRA,
                    18, 118, 128, 10, SS_NOTIFY
    LTEXT           "待機中", IDC_DIAG_LRA,
                    148, 118, 104, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "適用中の総ゲイン：", IDC_LABEL_DIAG_GAIN,
                    18, 128, 128, 10, SS_NOTIFY
    LTEXT           "待機中", IDC_DIAG_GAIN,
                    148, 128, 104, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "追加処理の状態：", IDC_LABEL_DIAG_PROCESSING,
                    18, 138, 128, 10, SS_NOTIFY
    LTEXT           "無効", IDC_DIAG_PROCESSING_RISK,
                    148, 138, 104, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "安全補正ゲイン：", IDC_LABEL_DIAG_SAFETY,
                    18, 148, 128, 10, SS_NOTIFY
    LTEXT           "無効", IDC_DIAG_SAFETY_REDUCTION,
                    148, 148, 104, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "コンプレッサー減衰量：", IDC_LABEL_DIAG_COMPRESSOR,
                    18, 158, 128, 10, SS_NOTIFY
    LTEXT           "無効", IDC_DIAG_COMPRESSOR_REDUCTION,
                    148, 158, 104, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "ソフトクリッパー減衰量：", IDC_LABEL_DIAG_CLIPPER,
                    18, 169, 128, 10, SS_NOTIFY
    LTEXT           "無効", IDC_DIAG_CLIPPER_REDUCTION,
                    148, 169, 104, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "True Peakリミッター減衰量：", IDC_LABEL_DIAG_LIMITER,
                    18, 180, 128, 10, SS_NOTIFY
    LTEXT           "待機中", IDC_DIAG_LIMITER_REDUCTION,
                    148, 180, 104, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "処理後True Peak：", IDC_LABEL_DIAG_TRUE_PEAK,
                    270, 48, 128, 10, SS_NOTIFY
    LTEXT           "待機中", IDC_DIAG_TRUE_PEAK,
                    400, 48, 102, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "True Peak保護状態：", IDC_LABEL_DIAG_PEAK_GUARD,
                    270, 59, 128, 10, SS_NOTIFY
    LTEXT           "待機中", IDC_DIAG_PEAK_GUARD,
                    400, 59, 102, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "処理遅延：", IDC_LABEL_DIAG_LATENCY,
                    270, 70, 128, 10, SS_NOTIFY
    LTEXT           "0.0 ms", IDC_DIAG_LATENCY,
                    400, 70, 102, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "サンプルレート：", IDC_LABEL_DIAG_SAMPLE_RATE,
                    270, 81, 128, 10, SS_NOTIFY
    LTEXT           "未検出", IDC_DIAG_SAMPLE_RATE,
                    400, 81, 102, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "チャンネル構成：", IDC_LABEL_DIAG_CHANNEL_LAYOUT,
                    270, 92, 128, 10, SS_NOTIFY
    LTEXT           "未検出", IDC_DIAG_CHANNEL_LAYOUT,
                    400, 92, 102, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "CPU負荷：", IDC_LABEL_DIAG_CPU,
                    270, 103, 128, 10, SS_NOTIFY
    LTEXT           "0.00 %", IDC_DIAG_CPU_LOAD,
                    400, 103, 102, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "0 dBTP超過イベント：", IDC_LABEL_DIAG_CLIP_EVENTS,
                    270, 114, 128, 10, SS_NOTIFY
    LTEXT           "0 回", IDC_DIAG_CLIP_EVENT_COUNT,
                    400, 114, 102, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "3バンド・アダプティブ減衰量：", IDC_LABEL_DIAG_THREE_BAND,
                    270, 125, 128, 10, SS_NOTIFY
    LTEXT           "無効", IDC_DIAG_THREE_BAND_REDUCTION,
                    400, 125, 102, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "最大True Peak：", IDC_LABEL_DIAG_MAX_TRUE_PEAK,
                    270, 136, 128, 10, SS_NOTIFY
    LTEXT           "未測定", IDC_DIAG_MAX_TRUE_PEAK,
                    400, 136, 102, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "最大コンプレッサー減衰量：", IDC_LABEL_DIAG_MAX_COMPRESSOR,
                    270, 147, 128, 10, SS_NOTIFY
    LTEXT           "0.00 dB", IDC_DIAG_MAX_COMPRESSOR_REDUCTION,
                    400, 147, 102, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "最大ソフトクリッパー減衰量：", IDC_LABEL_DIAG_MAX_CLIPPER,
                    270, 158, 128, 10, SS_NOTIFY
    LTEXT           "0.00 dB", IDC_DIAG_MAX_CLIPPER_REDUCTION,
                    400, 158, 102, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "最大True Peakリミッター減衰量：", IDC_LABEL_DIAG_MAX_LIMITER,
                    270, 169, 128, 10, SS_NOTIFY
    LTEXT           "0.00 dB", IDC_DIAG_MAX_LIMITER_REDUCTION,
                    400, 169, 102, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    LTEXT           "処理総合評価：", IDC_LABEL_DIAG_EVALUATION,
                    270, 180, 128, 10, SS_NOTIFY
    LTEXT           "未測定", IDC_DIAG_PROCESSING_EVALUATION,
                    400, 180, 102, 10, SS_LEFTNOWORDWRAP | SS_NOPREFIX

    GROUPBOX        "プリセット（上段：標準4種／下段：追加処理3種）",
                    -1, 8, 201, 504, 59
    PUSHBUTTON      "ナチュラル -18", IDC_PROFILE_STANDARD,
                    14, 214, 116, 17
    PUSHBUTTON      "パワーブースト -14", IDC_PROFILE_STREAMING,
                    136, 214, 116, 17
    PUSHBUTTON      "リラックス -23", IDC_PROFILE_BROADCAST,
                    258, 214, 116, 17
    PUSHBUTTON      "ナイトセーフ -22", IDC_PROFILE_NIGHT,
                    380, 214, 126, 17
    PUSHBUTTON      "モダンブースト -9", IDC_PROFILE_MODERN,
                    14, 234, 156, 17
    PUSHBUTTON      "1バンド・アダプティブ -10", IDC_PROFILE_ADAPTIVE,
                    176, 234, 156, 17
    PUSHBUTTON      "3バンド・アダプティブ -10", IDC_PROFILE_THREE_BAND,
                    338, 234, 168, 17

    GROUPBOX        "選択中のプリセット／比較",
                    -1, 8, 263, 504, 31
    LTEXT           "現在: ナチュラル -18",
                    IDC_PROFILE_DESCRIPTION,
                    14, 275, 200, 12, SS_LEFTNOWORDWRAP | SS_NOPREFIX
    CONTROL         "音量一致", IDC_COMPARE_LOUDNESS_MATCH, "Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP, 218, 273, 64, 13
    CONTROL         "比較（押している間）", IDC_ORIGINAL_COMPARE,
                    "Button", BS_PUSHBUTTON | BS_NOTIFY | WS_TABSTOP,
                    286, 271, 140, 17
    PUSHBUTTON      "ライセンス", IDC_SHOW_LICENSE,
                    432, 271, 74, 17

    PUSHBUTTON      "測定リセット", IDC_RESET_MEASUREMENT,
                    8, 303, 72, 15
    PUSHBUTTON      "診断コピー", IDC_COPY_DIAGNOSTICS,
                    84, 303, 68, 15
    LTEXT           "変更後は［適用］または［OK］",
                    IDC_APPLY_STATUS,
                    158, 305, 130, 12, SS_LEFTNOWORDWRAP | SS_NOPREFIX
    PUSHBUTTON      "用語集", IDC_SHOW_DIAGNOSTIC_HELP,
                    292, 303, 58, 15
    PUSHBUTTON      "初期設定", IDC_DEFAULTS,
                    354, 303, 44, 15
    PUSHBUTTON      "適用", IDC_APPLY_SETTINGS,
                    402, 303, 42, 15
    DEFPUSHBUTTON   "OK", IDOK,
                    448, 303, 30, 15
    PUSHBUTTON      "取消", IDCANCEL,
                    482, 303, 30, 15
END

IDD_R128_GLOSSARY DIALOGEX 0, 0, 400, 276
STYLE DS_SHELLFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_CONTROLPARENT
CAPTION "R128 音量ノーマライザー 用語集"
FONT 9, "Yu Gothic UI"
BEGIN
    LTEXT           "左の用語を選ぶと、このコンポーネント内での意味と読み方を表示します。",
                    -1, 10, 9, 380, 14
    LISTBOX         IDC_GLOSSARY_LIST, 10, 28, 150, 218,
                    LBS_NOTIFY | WS_VSCROLL | WS_TABSTOP | WS_BORDER
    EDITTEXT        IDC_GLOSSARY_DESCRIPTION, 168, 28, 222, 218,
                    ES_MULTILINE | ES_READONLY | ES_AUTOVSCROLL |
                    WS_VSCROLL | WS_TABSTOP | WS_BORDER
    DEFPUSHBUTTON   "閉じる", IDOK, 324, 254, 66, 16
END

IDD_R128_TEXT_INFO DIALOGEX 0, 0, 250, 210
STYLE DS_SHELLFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_CONTROLPARENT
CAPTION "R128 音量ノーマライザー"
FONT 9, "Yu Gothic UI"
BEGIN
    EDITTEXT        IDC_TEXT_INFO_BODY, 10, 10, 230, 166,
                    ES_MULTILINE | ES_READONLY | ES_AUTOVSCROLL |
                    WS_VSCROLL | WS_TABSTOP | WS_BORDER
    DEFPUSHBUTTON   "閉じる", IDOK, 174, 184, 66, 16
END

IDD_R128_CONFIRM_DEFAULTS DIALOGEX 0, 0, 260, 108
STYLE DS_SHELLFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_CONTROLPARENT
CAPTION "初期設定の確認"
FONT 9, "Yu Gothic UI"
BEGIN
    LTEXT           "現在の未適用変更を破棄し、すべての設定欄を初期設定へ戻します。\r\n［初期設定に戻す］のあと［適用］を押すと、再生中のDSPへ反映されます。\r\n続けますか？",
                    -1, 12, 12, 236, 52
    PUSHBUTTON      "初期設定に戻す", IDOK, 88, 80, 86, 16
    DEFPUSHBUTTON   "キャンセル", IDCANCEL, 180, 80, 68, 16
END

